# ============ Backend (Go) ============
DATABASE_URL=postgresql://lokalsicht:lokalsicht@localhost:5432/lokalsicht?sslmode=disable
PORT=5174

# Auth (shared between Next.js and Go)
NEXTAUTH_SECRET=local-dev-secret-32-chars-minimum!!

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
FRONTEND_URL=http://localhost:3000

# DeepSeek (AI)
DEEPSEEK_API_KEY=sk-xxx

# Resend (Email)
RESEND_API_KEY=re_xxx

# Encryption (AES-256 key for Google refresh tokens)
ENCRYPTION_KEY=32-char-random-string-for-aes!!

# Cron
CRON_API_KEY=local-cron-key-32-chars-minimum!!

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============ Frontend (Next.js) ============
NEXTAUTH_URL=http://localhost:3000
BACKEND_URL=http://localhost:5174

# Sentry (error monitoring)
SENTRY_DSN=
